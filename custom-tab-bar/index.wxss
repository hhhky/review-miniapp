.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(13, 14, 18, 0.88);
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  display: flex;
  justify-content: space-around;
  padding: 8px 0;
  padding-bottom: calc(8px + env(safe-area-inset-bottom));
  z-index: 100;
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.35);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  font-size: 20rpx;
  color: #6B7280;
  padding: 8rpx 32rpx;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.tab-item.active {
  color: #E67E22;
  font-weight: 600;
  background: rgba(230, 126, 34, 0.10);
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1;
}

.tab-text {
  font-size: 20rpx;
}
