.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.5);
  border-top: 1px solid rgba(255,255,255,0.6);
  display: flex;
  justify-content: space-around;
  padding: 8px 0;
  padding-bottom: calc(8px + env(safe-area-inset-bottom));
  z-index: 100;
  box-shadow: 0 -4rpx 24rpx rgba(37,99,235,0.04);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  font-size: 20rpx;
  color: #9ca3af;
  padding: 8rpx 32rpx;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.tab-item.active {
  color: #2563eb;
  font-weight: 600;
  background: rgba(37,99,235,0.08);
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1;
}

.tab-text {
  font-size: 20rpx;
}
