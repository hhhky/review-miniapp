/* ── Global Styles ─────────────────────────── */
page {
  --purple: #7c3aed;
  --purple-light: #8b5cf6;
  --pink: #ec4899;
  --green: #10b981;
  --red: #f43f5e;
  --gray-50: #f9fafb;
  --gray-100: #f3f4f6;
  --gray-200: #e5e7eb;
  --gray-400: #9ca3af;
  --gray-500: #6b7280;
  --gray-600: #4b5563;
  --gray-800: #1f2937;

  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: var(--gray-800);
  background-color: var(--gray-50);
  box-sizing: border-box;
}

/* ── Utility ──────────────────────────────── */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.gap-2 { gap: 8px; }
.gap-3 { gap: 12px; }
.gap-4 { gap: 16px; }
.text-center { text-align: center; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 20rpx; }
.text-gray { color: var(--gray-400); }
.text-white { color: #fff; }
.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.font-medium { font-weight: 500; }
.mt-2 { margin-top: 8px; }
.mt-4 { margin-top: 16px; }
.mb-2 { margin-bottom: 8px; }
.mb-4 { margin-bottom: 16px; }
.ml-2 { margin-left: 8px; }
.mr-2 { margin-right: 8px; }
.p-2 { padding: 8px; }
.p-3 { padding: 12px; }
.p-4 { padding: 16px; }
.px-3 { padding-left: 12px; padding-right: 12px; }
.py-2 { padding-top: 8px; padding-bottom: 8px; }
.rounded-full { border-radius: 999px; }
.rounded-xl { border-radius: 12px; }
.rounded-2xl { border-radius: 16px; }
.shadow-sm { box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.min-w-0 { min-width: 0; }
.shrink-0 { flex-shrink: 0; }
.w-full { width: 100%; }
.overflow-hidden { overflow: hidden; }
.relative { position: relative; }

/* ── Buttons ───────────────────────────────── */
.btn-primary {
  background: linear-gradient(135deg, #8b5cf6, #ec4899);
  color: #fff;
  border: none;
  border-radius: 999px;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-primary:active { opacity: 0.85; transform: scale(0.97); }

.btn-sm {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  border-radius: 999px;
}

.btn-outline {
  background: #fff;
  color: var(--purple);
  border: 2px solid var(--purple);
  border-radius: 999px;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-ghost {
  background: transparent;
  border: none;
  color: var(--gray-500);
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.btn-ghost:active { background: var(--gray-100); }

/* ── Cards ─────────────────────────────────── */
.card {
  background: rgba(255,255,255,0.8);
  border-radius: 16px;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.card:active { transform: scale(0.98); opacity: 0.9; }

/* ── Input ─────────────────────────────────── */
.input {
  width: 100%;
  padding: 20rpx 28rpx;
  border: 2px solid var(--gray-200);
  border-radius: 12px;
  font-size: 28rpx;
  color: var(--gray-800);
  background: #fff;
}

/* ── Modal ─────────────────────────────────── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 85%;
  max-width: 600rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--gray-800);
  margin-bottom: 24rpx;
}

/* ── Tabs ──────────────────────────────────── */
.tabs {
  display: flex;
  gap: 4px;
  padding: 4px;
  background: var(--gray-100);
  border-radius: 999px;
}

.tab-btn {
  flex: 1;
  padding: 12rpx 24rpx;
  border-radius: 999px;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--gray-500);
  background: transparent;
  border: none;
  text-align: center;
  transition: all 0.2s;
}

.tab-btn.active {
  background: #fff;
  color: var(--purple);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

/* ── Empty State ───────────────────────────── */
.empty {
  text-align: center;
  color: var(--gray-400);
  padding: 80rpx 0;
  font-size: 26rpx;
}

/* ── Category pills ────────────────────────── */
.cat-pill {
  display: inline-block;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── Badge ─────────────────────────────────── */
.badge {
  display: inline-flex;
  align-items: center;
  background: var(--gray-100);
  color: var(--gray-500);
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999px;
}
