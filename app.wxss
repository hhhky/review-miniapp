/* ── 琥珀暗夜 · 全局毛玻璃主题 ────────────────── */

page, view, text, input, textarea, button, image, scroll-view, swiper, swiper-item, navigator, picker, canvas {
  box-sizing: border-box;
}

page {
  /* ── 琥珀暗金调色板 ── */
  --amber:       #E67E22;
  --amber-light: #F59E0B;
  --amber-dark:  #D97706;
  --gold:        #F1C40F;
  --gold-soft:   rgba(241, 196, 15, 0.18);

  --gray-50:  #f9fafb;
  --gray-100: #f3f4f6;
  --gray-200: #e5e7eb;
  --gray-300: #d1d5db;
  --gray-400: #9ca3af;
  --gray-500: #6b7280;
  --gray-600: #4b5563;
  --gray-800: #1f2937;

  /* 暗夜玻璃令牌 */
  --glass-bg:        rgba(255, 255, 255, 0.03);
  --glass-bg-strong: rgba(255, 255, 255, 0.06);
  --glass-bg-hover:  rgba(255, 255, 255, 0.05);
  --glass-border:    rgba(255, 255, 255, 0.08);
  --glass-highlight: rgba(255, 255, 255, 0.05);
  --glass-shadow:    0 8px 32px 0 rgba(0, 0, 0, 0.37);
  --glass-shadow-sm: 0 4px 16px 0 rgba(0, 0, 0, 0.25);

  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: #E8E8ED;

  /* ── 深邃暗夜蓝 → 温暖琥珀金 弥散背景 ── */
  background:
    radial-gradient(circle at top right, rgba(230, 126, 34, 0.15), transparent 40%),
    radial-gradient(circle at bottom left, rgba(241, 196, 15, 0.1), transparent 50%),
    #0D0E12 !important;
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
}

/* ── Utility ──────────────────────────────── */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.gap-2 { gap: 8px; }
.gap-3 { gap: 12px; }
.gap-4 { gap: 16px; }
.text-center { text-align: center; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 20rpx; }
.text-gray { color: #A0A5B0; }
.text-white { color: #fff; }
.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.font-medium { font-weight: 500; }
.mt-2 { margin-top: 8px; }
.mt-4 { margin-top: 16px; }
.mb-2 { margin-bottom: 8px; }
.mb-3 { margin-bottom: 12px; }
.mb-4 { margin-bottom: 16px; }
.ml-2 { margin-left: 8px; }
.mr-2 { margin-right: 8px; }
.p-2 { padding: 8px; }
.p-3 { padding: 12px; }
.p-4 { padding: 16px; }
.px-2 { padding-left: 8px; padding-right: 8px; }
.px-3 { padding-left: 12px; padding-right: 12px; }
.py-2 { padding-top: 8px; padding-bottom: 8px; }
.rounded-full { border-radius: 999px; }
.rounded-xl { border-radius: 18rpx; }
.rounded-2xl { border-radius: 24rpx; }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.min-w-0 { min-width: 0; }
.shrink-0 { flex-shrink: 0; }
.w-full { width: 100%; }
.overflow-hidden { overflow: hidden; }
.relative { position: relative; }

/* ── Buttons (琥珀暗夜) ────────────────────── */
.btn-primary {
  background: #FFFFFF;
  color: #0D0E12;
  border: none;
  border-radius: 999px;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(230, 126, 34, 0.3);
}

.btn-primary:active { opacity: 0.88; transform: scale(0.97); }

.btn-sm {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  border-radius: 999px;
}

.btn-outline {
  background: var(--glass-bg);
  color: var(--amber);
  border: 1px solid rgba(230, 126, 34, 0.25);
  border-radius: 999px;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-ghost {
  background: transparent;
  border: none;
  color: #A0A5B0;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.btn-ghost:active { background: rgba(255,255,255,0.04); }

/* ── Glass Cards (暗夜) ────────────────────── */
.card, .glass-card {
  background: var(--glass-bg);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1px solid var(--glass-border);
  box-shadow: var(--glass-shadow-sm);
}

.card:active, .glass-card:active { transform: scale(0.98); opacity: 0.9; }

/* ── Glass Input (暗夜) ────────────────────── */
.input {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #E8E8ED;
  background: rgba(255,255,255,0.04);
  box-sizing: border-box;
  text-align: left;
}

.modal-box .input {
  width: 100%;
  box-sizing: border-box;
}

.input:focus {
  border-color: rgba(230, 126, 34, 0.35);
  background: rgba(255,255,255,0.06);
  box-shadow: 0 0 0 4rpx rgba(230, 126, 34, 0.08);
}

textarea.input {
  height: auto;
  min-height: 120rpx;
}

/* ── Glass Modal (暗夜) ────────────────────── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0,0,0,0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  overflow: hidden;
}

.modal-box {
  background: rgba(20, 22, 28, 0.92);
  border-radius: 36rpx;
  padding: 32rpx;
  width: 88%;
  max-width: 600rpx;
  max-height: 72vh;
  overflow-y: auto;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 24rpx 64rpx rgba(0,0,0,0.55), inset 0 1px 1px rgba(255,255,255,0.04);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  color: #E8E8ED;
  margin-bottom: 24rpx;
  word-break: break-all;
}

/* ── Bottom Fixed Sub-Tabs (暗夜) ──────────── */
.bottom-tabs {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 900;
  background: rgba(13, 14, 18, 0.85);
  border-top: 1px solid rgba(255,255,255,0.06);
  display: flex;
  justify-content: space-around;
  padding: 8px 0;
  padding-bottom: calc(8px + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.35);
}

.bottom-tabs .tabs {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
  gap: 0;
  width: 100%;
  display: flex;
  justify-content: space-around;
}

.bottom-tabs .tab-btn {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  font-size: 20rpx;
  color: #6B7280;
  padding: 8rpx 32rpx;
  border-radius: 20rpx;
  background: transparent;
  border: none;
  box-shadow: none;
}

.bottom-tabs .tab-btn.active {
  color: #E67E22;
  font-weight: 600;
  background: rgba(230, 126, 34, 0.10);
  border: none;
  box-shadow: none;
}

.bottom-tabs .tab-icon {
  font-size: 40rpx;
  line-height: 1;
}

.bottom-tabs .tab-text {
  font-size: 20rpx;
}

/* ── Glass Tabs (暗夜) ─────────────────────── */
.tabs {
  display: flex;
  gap: 4px;
  padding: 4px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 999px;
}

.tab-btn {
  flex: 1;
  padding: 12rpx 24rpx;
  border-radius: 999px;
  font-size: 24rpx;
  font-weight: 500;
  color: #6B7280;
  background: transparent;
  border: none;
  text-align: center;
}

.tab-btn.active {
  background: rgba(255,255,255,0.06);
  color: #E67E22;
  font-weight: 600;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* ── Empty State ───────────────────────────── */
.empty {
  text-align: center;
  color: #6B7280;
  padding: 80rpx 0;
  font-size: 26rpx;
}

/* ── Color Grid ─────────────────────────────── */
.color-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12rpx;
  justify-items: center;
}

/* ── Category pills ────────────────────────── */
.cat-pill {
  display: inline-block;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 6rpx currentColor;
}

/* ── Badge ─────────────────────────────────── */
.badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  color: #A0A5B0;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999px;
}

/* ── Floating Action Button (琥珀) ─────────── */
.fab {
  position: fixed;
  top: auto;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #E67E22;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 800;
  box-shadow: 0 8rpx 32rpx rgba(230, 126, 34, 0.35);
}

.fab:active {
  transform: scale(0.9);
  opacity: 0.9;
}

.fab-icon {
  font-size: 52rpx;
  color: #fff;
  line-height: 0;
  margin-top: -2rpx;
}

/* ── Shadow ────────────────────────────────── */
.shadow-sm { box-shadow: var(--glass-shadow-sm); }
