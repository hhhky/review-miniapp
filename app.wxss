/* ── Glassmorphism Global Styles ────────────────── */

page, view, text, input, textarea, button, image, scroll-view, swiper, swiper-item, navigator, picker, canvas {
  box-sizing: border-box;
}

page {
  --blue: #2563eb;
  --blue-light: #3b82f6;
  --green: #10b981;
  --teal: #06b6d4;
  --red: #f43f5e;
  --gray-50: #f9fafb;
  --gray-100: #f3f4f6;
  --gray-200: #e5e7eb;
  --gray-300: #d1d5db;
  --gray-400: #9ca3af;
  --gray-500: #6b7280;
  --gray-600: #4b5563;
  --gray-800: #1f2937;

  /* Glass color tokens */
  --glass-bg: rgba(255,255,255,0.45);
  --glass-bg-strong: rgba(255,255,255,0.65);
  --glass-bg-light: rgba(255,255,255,0.3);
  --glass-border: rgba(255,255,255,0.5);
  --glass-shadow: 0 4rpx 24rpx rgba(37,99,235,0.04), 0 2rpx 6rpx rgba(0,0,0,0.02);
  --glass-shadow-hover: 0 8rpx 36rpx rgba(37,99,235,0.08), 0 2rpx 8rpx rgba(0,0,0,0.03);

  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: var(--gray-800);

  /* Soft page gradient — glass-friendly backdrop */
  background: linear-gradient(170deg, #dbeafe 0%, #d1fae5 25%, #ffffff 55%, #ecfdf5 80%, #f0fdf4 100%);
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
}

/* ── Utility ──────────────────────────────── */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.gap-2 { gap: 8px; }
.gap-3 { gap: 12px; }
.gap-4 { gap: 16px; }
.text-center { text-align: center; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 20rpx; }
.text-gray { color: var(--gray-400); }
.text-white { color: #fff; }
.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.font-medium { font-weight: 500; }
.mt-2 { margin-top: 8px; }
.mt-4 { margin-top: 16px; }
.mb-2 { margin-bottom: 8px; }
.mb-3 { margin-bottom: 12px; }
.mb-4 { margin-bottom: 16px; }
.ml-2 { margin-left: 8px; }
.mr-2 { margin-right: 8px; }
.p-2 { padding: 8px; }
.p-3 { padding: 12px; }
.p-4 { padding: 16px; }
.px-2 { padding-left: 8px; padding-right: 8px; }
.px-3 { padding-left: 12px; padding-right: 12px; }
.py-2 { padding-top: 8px; padding-bottom: 8px; }
.rounded-full { border-radius: 999px; }
.rounded-xl { border-radius: 18rpx; }
.rounded-2xl { border-radius: 24rpx; }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.min-w-0 { min-width: 0; }
.shrink-0 { flex-shrink: 0; }
.w-full { width: 100%; }
.overflow-hidden { overflow: hidden; }
.relative { position: relative; }

/* ── Buttons ───────────────────────────────── */
.btn-primary {
  background: linear-gradient(135deg, #2563eb, #10b981);
  color: #fff;
  border: none;
  border-radius: 999px;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(37,99,235,0.2);
}

.btn-primary:active { opacity: 0.85; transform: scale(0.97); }

.btn-sm {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  border-radius: 999px;
}

.btn-outline {
  background: var(--glass-bg);
  color: var(--blue);
  border: 1px solid rgba(37,99,235,0.25);
  border-radius: 999px;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: var(--glass-shadow);
}

.btn-ghost {
  background: transparent;
  border: none;
  color: var(--gray-500);
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.btn-ghost:active { background: rgba(37,99,235,0.06); }

/* ── Glass Cards ────────────────────────────── */
.card, .glass-card {
  background: var(--glass-bg);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1px solid var(--glass-border);
  box-shadow: var(--glass-shadow);
}

.card:active, .glass-card:active { transform: scale(0.98); opacity: 0.9; }

/* ── Glass Input ────────────────────────────── */
.input {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 1px solid rgba(255,255,255,0.5);
  border-radius: 18rpx;
  font-size: 28rpx;
  color: var(--gray-800);
  background: rgba(255,255,255,0.55);
  box-sizing: border-box;
  text-align: left;
}

.modal-box .input {
  width: 100%;
  box-sizing: border-box;
}

.input:focus {
  border-color: rgba(37,99,235,0.4);
  background: rgba(255,255,255,0.65);
  box-shadow: 0 0 0 4rpx rgba(37,99,235,0.06);
}

textarea.input {
  height: auto;
  min-height: 120rpx;
}

/* ── Glass Modal ────────────────────────────── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0,0,0,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  overflow: hidden;
}

.modal-box {
  background: rgba(255,255,255,0.75);
  border-radius: 36rpx;
  padding: 32rpx;
  width: 88%;
  max-width: 600rpx;
  max-height: 72vh;
  overflow-y: auto;
  border: 1px solid rgba(255,255,255,0.6);
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.08), 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  color: var(--blue);
  margin-bottom: 24rpx;
  word-break: break-all;
}

/* ── Bottom Fixed Sub-Tabs ──────────────────── */
.bottom-tabs {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 900;
  background: rgba(255,255,255,0.5);
  border-top: 1px solid rgba(255,255,255,0.6);
  display: flex;
  justify-content: space-around;
  padding: 8px 0;
  padding-bottom: calc(8px + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(37,99,235,0.04);
}

.bottom-tabs .tabs {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
  gap: 0;
  width: 100%;
  display: flex;
  justify-content: space-around;
}

.bottom-tabs .tab-btn {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  font-size: 20rpx;
  color: #9ca3af;
  padding: 8rpx 32rpx;
  border-radius: 20rpx;
  background: transparent;
  border: none;
  box-shadow: none;
}

.bottom-tabs .tab-btn.active {
  color: #2563eb;
  font-weight: 600;
  background: rgba(37,99,235,0.08);
  border: none;
  box-shadow: none;
}

.bottom-tabs .tab-icon {
  font-size: 40rpx;
  line-height: 1;
}

.bottom-tabs .tab-text {
  font-size: 20rpx;
}

/* ── Glass Tabs ─────────────────────────────── */
.tabs {
  display: flex;
  gap: 4px;
  padding: 4px;
  background: rgba(255,255,255,0.3);
  border: 1px solid rgba(255,255,255,0.4);
  border-radius: 999px;
}

.tab-btn {
  flex: 1;
  padding: 12rpx 24rpx;
  border-radius: 999px;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--gray-500);
  background: transparent;
  border: none;
  text-align: center;
  transition: all 0.2s;
}

.tab-btn.active {
  background: var(--glass-bg-strong);
  color: var(--blue);
  font-weight: 600;
  border: 1px solid rgba(255,255,255,0.5);
  box-shadow: 0 2rpx 8rpx rgba(37,99,235,0.06);
}

/* ── Empty State ───────────────────────────── */
.empty {
  text-align: center;
  color: var(--gray-400);
  padding: 80rpx 0;
  font-size: 26rpx;
}

/* ── Color Grid ─────────────────────────────── */
.color-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12rpx;
  justify-items: center;
}

/* ── Category pills ────────────────────────── */
.cat-pill {
  display: inline-block;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 6rpx currentColor;
}

/* ── Badge ─────────────────────────────────── */
.badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.4);
  border: 1px solid rgba(255,255,255,0.4);
  color: var(--gray-500);
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999px;
}

/* ── Floating Action Button ─────────────────── */
.fab {
  position: fixed;
  top: auto;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563eb, #10b981);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 800;
  box-shadow: 0 8rpx 32rpx rgba(37,99,235,0.3);
}

.fab:active {
  transform: scale(0.9);
  opacity: 0.9;
}

.fab-icon {
  font-size: 52rpx;
  color: #fff;
  line-height: 0;
  margin-top: -2rpx;
}

/* ── Glass Shadow ──────────────────────────── */
.shadow-sm {
  box-shadow: var(--glass-shadow);
}
