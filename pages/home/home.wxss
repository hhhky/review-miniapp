.page-home {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* ── Header ────────────────────────────────── */
.home-header {
  padding: 40rpx 32rpx 24rpx;
}

.home-title {
  font-size: 44rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #2563eb, #10b981);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.home-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--gray-400);
  margin-top: 6rpx;
}

/* ── 双列 Flex 容器（底部对齐） ────────────── */
.widgets-row {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  align-items: stretch;
}

.widgets-left {
  flex: 1;
  min-width: 0;
}

.widgets-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ── 卡片通用 ──────────────────────────────── */
.widget-card {
  cursor: pointer;
}

.widget-card-tall {
  height: 100%;
}

.widget-card-square {
  flex: 1;
}

.widget-card-inner {
  border-radius: 36rpx;
  background: rgba(255,255,255,0.4);
  border: 1px solid rgba(255,255,255,0.5);
  box-shadow: 0 4rpx 24rpx rgba(37,99,235,0.04), 0 2rpx 6rpx rgba(0,0,0,0.02);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.widget-card-inner::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, rgba(37,99,235,0.04), rgba(16,185,129,0.03), rgba(59,130,246,0.03));
  pointer-events: none;
  border-radius: inherit;
}

.widget-card-inner:active {
  transform: scale(0.98);
  opacity: 0.9;
  box-shadow: 0 2rpx 12rpx rgba(37,99,235,0.06);
}

/* ── Tall 卡片（竖向填满左列） ─────────────── */
.card-inner-tall {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 48rpx 28rpx;
  gap: 24rpx;
  height: 100%;
  box-sizing: border-box;
}

.icon-wrap-tall {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.15);
}

.icon-tall {
  font-size: 64rpx;
}

.widget-info-tall {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* ── Square 卡片（横向） ───────────────────── */
.card-inner-square {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 24rpx;
  height: 100%;
  box-sizing: border-box;
}

.icon-wrap-square {
  width: 80rpx;
  height: 80rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.15);
}

.icon-square {
  font-size: 40rpx;
}

/* ── 信息区 ────────────────────────────────── */
.widget-info {
  flex: 1;
  min-width: 0;
}

.widget-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--gray-800);
}

.widget-desc {
  display: block;
  font-size: 24rpx;
  color: var(--gray-400);
  margin-top: 4rpx;
}

.widget-arrow {
  font-size: 36rpx;
  color: var(--gray-300);
  flex-shrink: 0;
}

/* ── Footer ────────────────────────────────── */
.home-footer {
  text-align: center;
  padding: 40rpx;
}
