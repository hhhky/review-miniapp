/* ── 琥珀仪表盘 · 首页 ─────────────────────── */

.page-home {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* ── Header ────────────────────────────────── */
.home-header {
  padding: 56rpx 40rpx 16rpx;
}

.home-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.home-subtitle {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 6rpx;
  letter-spacing: 1rpx;
}

/* ── Dashboard Grid ────────────────────────── */
.dash-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  align-items: start;
}

/* ── 通用卡片底座 ──────────────────────────── */
.dash-card {
  position: relative;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.03);
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 8px 32px 0 rgba(0, 0, 0, 0.37),
    inset 0 1px 1px rgba(255, 255, 255, 0.05);
  overflow: hidden;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.dash-card:active {
  transform: scale(0.975);
  box-shadow:
    0 4px 16px 0 rgba(0, 0, 0, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.03);
}

/* ── 卡片内部高光线 ────────────────────────── */
.card-glow-line {
  position: absolute;
  top: 0;
  left: 20rpx;
  right: 20rpx;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
  pointer-events: none;
}

/* ── Tall 卡片（左列，跨2行） ──────────────── */
.dash-card-tall {
  grid-row: span 2;
}

.card-body-tall {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 36rpx;
  gap: 24rpx;
  text-align: center;
}

.dash-card-tall .card-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dash-card-tall .card-icon {
  font-size: 60rpx;
}

.dash-card-tall .card-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
}

.dash-card-tall .card-desc {
  font-size: 24rpx;
  color: #A0A5B0;
  display: block;
  margin-top: 8rpx;
  line-height: 1.5;
}

.dash-card-tall .card-arrow {
  font-size: 32rpx;
  color: rgba(255,255,255,0.20);
  margin-top: 4rpx;
}

/* 底部琥珀微光条 */
.card-bottom-accent {
  height: 2px;
  margin: 0 32rpx 36rpx;
  border-radius: 1px;
}

/* ── Square 卡片（右列，紧凑方卡） ─────────── */
.card-body-square {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 16rpx;
}

.dash-card-square .card-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dash-card-square .card-icon {
  font-size: 36rpx;
}

.dash-card-square .card-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
}

.dash-card-square .card-desc {
  font-size: 22rpx;
  color: #A0A5B0;
  display: block;
  margin-top: 4rpx;
  line-height: 1.4;
}

.dash-card-square .card-text {
  flex: 1;
  min-width: 0;
}

/* ── Footer ────────────────────────────────── */
.home-footer {
  text-align: center;
  padding: 48rpx;
}
