<view class="page-home">
  <!-- 头部 -->
  <view class="home-header">
    <text class="home-title">实用部件</text>
    <text class="home-subtitle">{{widgets.length}} 个部件 · 点击进入</text>
  </view>

  <!-- 金刚区卡片 -->
  <view class="widgets-grid">
    <view
      wx:for="{{widgets}}"
      wx:key="id"
      class="widget-card"
      data-id="{{item.id}}"
      bindtap="enterWidget"
    >
      <view class="widget-card-inner" style="background: linear-gradient(135deg, {{item.color}}11, {{item.color}}22);">
        <view class="widget-icon-wrap" style="background: linear-gradient(135deg, {{item.color}}, {{item.color}}dd);">
          <text class="widget-icon">{{item.icon}}</text>
        </view>
        <view class="widget-info">
          <text class="widget-name">{{item.name}}</text>
          <text class="widget-desc">{{item.desc}}</text>
        </view>
        <text class="widget-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="home-footer">
    <text class="text-xs text-gray">powered by hhhky</text>
  </view>
</view>
