<view class="page-home">
  <!-- 头部 -->
  <view class="home-header">
    <text class="home-title">实用部件</text>
    <text class="home-subtitle">{{widgets.length}} 个部件 · 点击进入</text>
  </view>

  <!-- 双列布局：左 tall + 右 square×2，底部对齐 -->
  <view class="widgets-row">
    <!-- 左列 -->
    <view class="widgets-left">
      <view
        wx:for="{{widgets}}"
        wx:key="id"
        wx:if="{{index === 0}}"
        class="widget-card widget-card-tall"
        data-id="{{item.id}}"
        bindtap="enterWidget"
      >
        <view class="widget-card-inner card-inner-tall"
          style="background: linear-gradient(135deg, {{item.color}}11, {{item.color}}22);">
          <view class="widget-icon-wrap icon-wrap-tall"
            style="background: linear-gradient(135deg, {{item.color}}, {{item.color}}dd);">
            <text class="widget-icon icon-tall">{{item.icon}}</text>
          </view>
          <view class="widget-info widget-info-tall">
            <text class="widget-name">{{item.name}}</text>
            <text class="widget-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 右列 -->
    <view class="widgets-right">
      <view
        wx:for="{{widgets}}"
        wx:key="id"
        wx:if="{{index > 0}}"
        class="widget-card widget-card-square"
        data-id="{{item.id}}"
        bindtap="enterWidget"
      >
        <view class="widget-card-inner card-inner-square"
          style="background: linear-gradient(135deg, {{item.color}}11, {{item.color}}22);">
          <view class="widget-icon-wrap icon-wrap-square"
            style="background: linear-gradient(135deg, {{item.color}}, {{item.color}}dd);">
            <text class="widget-icon icon-square">{{item.icon}}</text>
          </view>
          <view class="widget-info">
            <text class="widget-name">{{item.name}}</text>
            <text class="widget-desc">{{item.desc}}</text>
          </view>
          <text class="widget-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="home-footer">
    <text class="text-xs text-gray">powered by hhhky</text>
  </view>
</view>
