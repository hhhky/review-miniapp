/* ── 思维导图 · 琥珀暗夜 ────────────────────── */

.page-mindmap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 140rpx;
}

.tab-content {
  flex: 1;
  padding-top: 16rpx;
  padding-bottom: 60rpx;
}

/* ── Glass Workflow Cards ─────────────────── */
.wf-card {
  cursor: pointer;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 999px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.06);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #E67E22, #F59E0B);
  border-radius: 999px;
  transition: width 0.3s;
}

/* ── Glass Mind Map Detail ────────────────── */
.mindmap-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.detail-header {
  background: rgba(255,255,255,0.03);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  flex-shrink: 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.2);
}

.zoom-label {
  font-size: 22rpx;
  color: #6B7280;
  padding: 8rpx;
}

.mindmap-canvas {
  flex: 1;
  width: 100%;
}

/* ── Hints ────────────────────────────────── */
.mindmap-hints {
  padding: 8rpx 16rpx;
  text-align: center;
  flex-shrink: 0;
  background: rgba(255,255,255,0.03);
  border-top: 1px solid rgba(255,255,255,0.06);
}

.mindmap-hints text {
  font-size: 20rpx;
  color: #6B7280;
}

/* ── Glass Shape & Size Buttons ───────────── */
.shape-btn, .size-btn {
  padding: 12rpx 32rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  background: rgba(255,255,255,0.04);
  color: #6B7280;
  border: 1px solid rgba(255,255,255,0.06);
}

.shape-btn.active, .size-btn.active {
  background: rgba(230,126,34,0.08);
  color: #E67E22;
  border-color: rgba(230,126,34,0.25);
}
