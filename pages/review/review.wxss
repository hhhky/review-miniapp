/* ── 资料管理 · 琥珀暗夜 ────────────────────── */

.page-review {
  width: 100%;
  min-height: 100vh;
  padding-bottom: 140rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.tab-content {
  width: 100%;
  padding-top: 16rpx;
  box-sizing: border-box;
}

/* ── Glass Category Items ─────────────────── */
.category-item {
  cursor: pointer;
  display: flex;
  border: 1px solid rgba(255,255,255,0.07);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.category-item .edit-btn {
  background: rgba(255,255,255,0.06);
  color: #A0A5B0;
  padding: 8rpx 20rpx;
  border-radius: 999px;
  font-size: 22rpx;
  border: 1px solid rgba(255,255,255,0.08);
}

.category-item .delete-btn {
  background: rgba(244,63,94,0.08);
  color: #f87171;
  padding: 8rpx 20rpx;
  border-radius: 999px;
  font-size: 22rpx;
  border: 1px solid rgba(244,63,94,0.12);
}

/* ── Glass Filter Bar ─────────────────────── */
.filter-bar {
  white-space: nowrap;
}

.filter-pill {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 999px;
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  color: #6B7280;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.filter-pill.active {
  background: #E67E22;
  color: #fff;
  font-weight: 600;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(230,126,34,0.3);
}

/* ── Glass File Items ─────────────────────── */
.file-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  position: static;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.file-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}

.file-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.file-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #E8E8ED;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-meta {
  display: block;
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 4rpx;
}

.file-actions {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 999px;
  font-size: 22rpx;
  font-weight: 500;
}

.action-rename {
  color: #E67E22;
  background: rgba(230,126,34,0.08);
  border: 1px solid rgba(230,126,34,0.12);
}

.action-delete {
  color: #f87171;
  background: rgba(244,63,94,0.06);
  border: 1px solid rgba(244,63,94,0.10);
}

/* ── Glass Upload Cat ─────────────────────── */
.upload-cat-item {
  background: rgba(255,255,255,0.03);
  cursor: pointer;
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(255,255,255,0.07);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.upload-cat-item.active {
  background: rgba(230,126,34,0.08);
  border-color: rgba(230,126,34,0.3);
  box-shadow: 0 0 0 3rpx rgba(230,126,34,0.12);
}

/* ── Color Picker ─────────────────────────── */
.color-option {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  border: 2rpx solid rgba(255,255,255,0.08);
}

.color-option.active {
  transform: scale(1.15);
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.25);
}

/* ── Disabled Button ──────────────────────── */
.btn-primary.disabled {
  opacity: 0.4;
  pointer-events: none;
}
