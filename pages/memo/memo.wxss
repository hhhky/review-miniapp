.page-memo {
  width: 100%;
  min-height: 100vh;
  padding-bottom: 140rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.tab-content {
  width: 100%;
  padding-top: 16rpx;
  box-sizing: border-box;
}

/* ── Glass Memo Card ──────────────────────── */
.memo-card {
  cursor: pointer;
  background: rgba(255,255,255,0.4);
  border: 1px solid rgba(255,255,255,0.5);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(37,99,235,0.03), 0 1rpx 4rpx rgba(0,0,0,0.02);
}

/* ── Glass Calendar ───────────────────────── */
.cal-row {
  display: flex;
}

.cal-header {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--gray-400);
  padding: 12rpx 0;
}

.cal-grid {
  display: flex;
  flex-wrap: wrap;
  background: rgba(255,255,255,0.3);
  border: 1px solid rgba(255,255,255,0.4);
  border-radius: 20rpx;
  overflow: hidden;
}

.cal-cell {
  width: calc(100% / 7);
  height: 0;
  padding-bottom: calc(100% / 7);
  position: relative !important;
  box-sizing: border-box;
  overflow: visible !important;
}

.cal-cell-inner {
  position: absolute !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  border-radius: 16rpx;
  overflow: visible !important;
}

.cal-highlight {
  position: absolute !important;
  left: auto !important;
  top: auto !important;
  transform: none !important;
  width: 60rpx !important;
  height: 60rpx !important;
  border-radius: 50% !important;
  background: rgba(37,99,235,0.08) !important;
  z-index: 1 !important;
}

.cal-highlight.selected {
  background: rgba(37,99,235,0.12) !important;
  box-shadow: inset 0 0 0 2rpx rgba(37,99,235,0.25) !important;
}

.cal-day {
  position: relative !important;
  z-index: 2 !important;
  font-size: 26rpx;
}

.cal-dot {
  position: relative !important;
  z-index: 2 !important;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-top: 2rpx;
}

.cal-cell.other-month .cal-day {
  color: var(--gray-300);
}

.cal-cell.today .cal-day {
  font-weight: 700;
  color: var(--blue);
}

.cal-cell.selected .cal-day {
  color: var(--blue);
  font-weight: 700;
}

/* ── Memo Modal Layout Fix ──────────────────── */
.page-memo .modal-box {
  display: flex;
  flex-direction: column;
}

.page-memo .modal-box .btn-row {
  flex-shrink: 0;
}

.page-memo .modal-box input,
.page-memo .modal-box textarea {
  color: #333333 !important;
  font-size: 28rpx !important;
  background-color: #f5f5f5 !important;
}

.page-memo .modal-box input::placeholder,
.page-memo .modal-box textarea::placeholder {
  color: #9ca3af !important;
}
