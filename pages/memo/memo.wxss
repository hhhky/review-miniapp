.page-memo {
  width: 100%;
  min-height: 100vh;
  padding-bottom: 140rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.tab-content {
  width: 100%;
  padding-top: 16rpx;
  box-sizing: border-box;
}

/* ── Glass Memo Card ──────────────────────── */
.memo-card {
  cursor: pointer;
  background: rgba(255,255,255,0.4);
  border: 1px solid rgba(255,255,255,0.5);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(37,99,235,0.03), 0 1rpx 4rpx rgba(0,0,0,0.02);
}

/* ── Glass Calendar ───────────────────────── */
.cal-row {
  display: flex;
}

.cal-header {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--gray-400);
  padding: 12rpx 0;
}

.cal-grid {
  display: flex;
  flex-wrap: wrap;
  background: rgba(255,255,255,0.3);
  border: 1px solid rgba(255,255,255,0.4);
  border-radius: 20rpx;
  overflow: hidden;
}

.cal-cell {
  width: calc(100% / 7);
  min-height: 170rpx;
  box-sizing: border-box;
  overflow: hidden;
  border-right: 1px solid rgba(255,255,255,0.2);
  border-bottom: 1px solid rgba(255,255,255,0.2);
}

.cal-cell-inner {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 12rpx 8rpx 8rpx;
  height: 100%;
  box-sizing: border-box;
  position: relative;
}

.cal-highlight {
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(37,99,235,0.08);
  z-index: 1;
  pointer-events: none;
}

.cal-highlight.selected {
  background: rgba(37,99,235,0.12);
  box-shadow: inset 0 0 0 2rpx rgba(37,99,235,0.25);
}

/* 日期行：数字 + 小圆点 */
.cal-day-row {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 6rpx;
}

.cal-day {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--gray-800);
  line-height: 1.2;
}

.cal-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.cal-cell.other-month .cal-day {
  color: var(--gray-300);
}

.cal-cell.today .cal-day {
  font-weight: 700;
  color: var(--blue);
}

.cal-cell.selected .cal-day {
  color: var(--blue);
  font-weight: 700;
}

/* ── 待办标签容器 ────────────────────────── */
.day-todo-container {
  position: relative;
  z-index: 2;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
}

.todo-tag-item {
  font-size: 18rpx;
  line-height: 1.3;
  padding: 3rpx 8rpx;
  border-radius: 6rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.todo-more {
  font-size: 16rpx;
  color: var(--gray-400);
  padding-left: 4rpx;
}

/* ── Memo Modal Layout Fix ──────────────────── */
.page-memo .modal-box {
  display: flex;
  flex-direction: column;
}

.page-memo .modal-box .btn-row {
  flex-shrink: 0;
}

.page-memo .modal-box input,
.page-memo .modal-box textarea {
  color: #333333 !important;
  font-size: 28rpx !important;
  background-color: #f5f5f5 !important;
}

.page-memo .modal-box input::placeholder,
.page-memo .modal-box textarea::placeholder {
  color: #9ca3af !important;
}
