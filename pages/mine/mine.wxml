<view class="page-mine">

  <!-- 头部：头像 + 昵称 -->
  <view class="mine-header">
    <view class="avatar-wrap" bindtap="onAvatarTap">
      <view class="avatar">
        <image wx:if="{{isImageAvatar}}" class="avatar-img" src="{{profile.avatar}}" mode="aspectFill" />
        <text wx:else>{{profile.avatar || '👤'}}</text>
      </view>
      <view class="avatar-edit-badge">📷</view>
    </view>

    <view class="nickname-row" bindtap="onNicknameTap">
      <text class="nickname-text">{{profile.nickname || '点击设置昵称'}}</text>
      <text class="nickname-edit-icon">✏️</text>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="section">
    <text class="section-title">数据统计</text>
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">📁</text>
        <text class="stat-num">{{fileCount}}</text>
        <text class="stat-label">资料总数</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">📝</text>
        <text class="stat-num">{{memoCount}}</text>
        <text class="stat-label">备忘录</text>
      </view>
    </view>
  </view>

  <!-- 功能设置 -->
  <view class="section">
    <text class="section-title">设置</text>
    <view class="settings-list">
      <view class="setting-item" bindtap="onNicknameTap">
        <text class="setting-icon">✏️</text>
        <text class="setting-text">修改昵称</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="onAvatarTap">
        <text class="setting-icon">📷</text>
        <text class="setting-text">更换头像</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- ── 昵称编辑弹窗 ── -->
  <view class="modal-mask" wx:if="{{showNicknameModal}}" bindtap="onCloseNicknameModal">
    <view class="modal-box" catchtap="onStopPropagation">
      <view class="modal-title">修改昵称</view>
      <input
        class="input"
        placeholder="请输入昵称（最多20字）"
        maxlength="20"
        value="{{nicknameInput}}"
        bindinput="onNicknameInput"
        focus="{{true}}"
      />
      <view wx:if="{{nicknameError}}" class="error-msg">{{nicknameError}}</view>
      <view class="flex gap-3 justify-between" style="margin-top:40rpx;">
        <view class="btn-cancel flex-1 text-center" bindtap="onCloseNicknameModal">取消</view>
        <view class="btn-primary flex-1 text-center" style="height:80rpx;line-height:80rpx;border-radius:20rpx;padding:0;" bindtap="onConfirmNickname">确定</view>
      </view>
    </view>
  </view>

  <!-- ── 头像选择弹窗 ── -->
  <view class="modal-mask" wx:if="{{showAvatarModal}}" bindtap="onCloseAvatarModal">
    <view class="modal-box" catchtap="onStopPropagation">
      <view class="modal-title">选择头像</view>

      <!-- 预设头像 -->
      <view class="avatar-presets">
        <view
          wx:for="{{presetAvatars}}"
          wx:key="*this"
          class="preset-avatar {{profile.avatar === item ? 'active' : ''}}"
          data-avatar="{{item}}"
          bindtap="onSelectPreset"
        >
          <text>{{item}}</text>
        </view>
      </view>

      <!-- 从相册选择 -->
      <view class="btn-outline text-center mt-4" bindtap="onChooseFromAlbum" style="display:block;box-sizing:border-box;">从相册选择</view>

      <view class="flex justify-center" style="margin-top:32rpx;">
        <view class="btn-cancel flex-1 text-center" bindtap="onCloseAvatarModal">关闭</view>
      </view>
    </view>
  </view>

</view>
