<view class="page-mine">
  <!-- 头部 -->
  <view class="mine-header">
    <view class="avatar">👤</view>
    <text class="font-bold" style="font-size:36rpx;color:#fff;margin-top:12rpx;">我的</text>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-section p-4">
    <text class="font-semibold" style="font-size:30rpx;display:block;margin-bottom:20rpx;">数据统计</text>
    <view class="stats-grid">
      <view class="stat-card rounded-2xl p-4">
        <text style="font-size:48rpx;">📁</text>
        <text class="font-bold" style="font-size:40rpx;color:var(--blue);">{{fileCount}}</text>
        <text class="text-xs text-gray">资料总数</text>
      </view>
      <view class="stat-card rounded-2xl p-4">
        <text style="font-size:48rpx;">📝</text>
        <text class="font-bold" style="font-size:40rpx;color:var(--green);">{{memoCount}}</text>
        <text class="text-xs text-gray">备忘录</text>
      </view>
    </view>
  </view>


</view>
