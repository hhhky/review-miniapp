.page-mine {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ── Header ──────────────────────────── */
.mine-header {
  background: linear-gradient(170deg, rgba(37,99,235,0.12), rgba(59,130,246,0.08), rgba(16,185,129,0.06));
  padding: 80rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-bottom: 1px solid rgba(255,255,255,0.5);
}

.avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  border: 3rpx solid rgba(255,255,255,0.7);
  box-shadow: 0 8rpx 32rpx rgba(37,99,235,0.08);
  transition: transform 0.2s;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar:active {
  transform: scale(0.95);
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.85);
  border: 2rpx solid rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 32rpx;
  border-radius: 999px;
  background: rgba(255,255,255,0.4);
  border: 1px solid rgba(255,255,255,0.5);
  box-shadow: 0 2rpx 12rpx rgba(37,99,235,0.04);
}

.nickname-row:active {
  background: rgba(37,99,235,0.06);
}

.nickname-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nickname-edit-icon {
  font-size: 24rpx;
  opacity: 0.5;
}

/* ── Sections ─────────────────────────── */
.section {
  margin: 24rpx 24rpx 0;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #6b7280;
  margin-bottom: 16rpx;
  display: block;
  padding-left: 8rpx;
}

/* ── Stats ────────────────────────────── */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: rgba(255,255,255,0.4);
  border: 1px solid rgba(255,255,255,0.5);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(37,99,235,0.03), 0 1rpx 4rpx rgba(0,0,0,0.02);
}

.stat-icon {
  font-size: 48rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #2563eb;
}

.stat-label {
  font-size: 22rpx;
  color: #9ca3af;
}

/* ── Settings ─────────────────────────── */
.settings-list {
  background: rgba(255,255,255,0.4);
  border: 1px solid rgba(255,255,255,0.5);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(37,99,235,0.03), 0 1rpx 4rpx rgba(0,0,0,0.02);
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  border-bottom: 1px solid rgba(255,255,255,0.4);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: rgba(37,99,235,0.04);
}

.setting-icon {
  font-size: 32rpx;
}

.setting-text {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.setting-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  font-weight: 300;
}

/* ── Error ─────────────────────────────── */
.error-msg {
  color: #f43f5e;
  font-size: 24rpx;
  margin-top: 12rpx;
  text-align: center;
}

/* ── Avatar Presets ───────────────────── */
.avatar-presets {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
  justify-items: center;
  margin-bottom: 24rpx;
}

.preset-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  border: 2rpx solid rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(37,99,235,0.04);
}

.preset-avatar.active {
  border-color: #2563eb;
  background: rgba(37,99,235,0.1);
  box-shadow: 0 0 0 4rpx rgba(37,99,235,0.12);
}

.preset-avatar:active {
  transform: scale(0.9);
}

/* ── Modal Buttons ────────────────────── */
.modal-btns {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
}
