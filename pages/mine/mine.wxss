.page-mine {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ── Glass Header ─────────────────────────── */
.mine-header {
  background: linear-gradient(170deg, rgba(37,99,235,0.12), rgba(59,130,246,0.08), rgba(16,185,129,0.06));
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-bottom: 1px solid rgba(255,255,255,0.5);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  border: 2rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.06);
}

/* ── Glass Stats ──────────────────────────── */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: rgba(255,255,255,0.4);
  border: 1px solid rgba(255,255,255,0.5);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(37,99,235,0.03), 0 1rpx 4rpx rgba(0,0,0,0.02);
}
