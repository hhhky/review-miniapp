/* ── 我的 · 琥珀暗夜 ────────────────────────── */

.page-mine {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ── Header ──────────────────────────── */
.mine-header {
  background: linear-gradient(170deg, rgba(230,126,34,0.08), rgba(245,158,11,0.04), rgba(241,196,15,0.03));
  padding: 80rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  border: 3rpx solid rgba(255,255,255,0.10);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.35);
  transition: transform 0.2s;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar:active {
  transform: scale(0.95);
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(20,22,28,0.9);
  border: 2rpx solid rgba(255,255,255,0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 32rpx;
  border-radius: 999px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.2);
}

.nickname-row:active {
  background: rgba(230,126,34,0.06);
}

.nickname-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #E8E8ED;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nickname-edit-icon {
  font-size: 24rpx;
  opacity: 0.4;
}

/* ── Sections ─────────────────────────── */
.section {
  margin: 24rpx 24rpx 0;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #6B7280;
  margin-bottom: 16rpx;
  display: block;
  padding-left: 8rpx;
}

/* ── Stats ────────────────────────────── */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2), 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.stat-icon {
  font-size: 48rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #E67E22;
}

.stat-label {
  font-size: 22rpx;
  color: #6B7280;
}

/* ── Settings ─────────────────────────── */
.settings-list {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2), 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: rgba(230,126,34,0.04);
}

.setting-icon {
  font-size: 32rpx;
}

.setting-text {
  flex: 1;
  font-size: 28rpx;
  color: #D1D5DB;
  font-weight: 500;
}

.setting-arrow {
  font-size: 36rpx;
  color: rgba(255,255,255,0.12);
  font-weight: 300;
}

/* ── Error ─────────────────────────────── */
.error-msg {
  color: #f87171;
  font-size: 24rpx;
  margin-top: 12rpx;
  text-align: center;
}

/* ── Avatar Presets ───────────────────── */
.avatar-presets {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
  justify-items: center;
  margin-bottom: 24rpx;
}

.preset-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
  border: 2rpx solid rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.preset-avatar.active {
  border-color: #E67E22;
  background: rgba(230,126,34,0.12);
  box-shadow: 0 0 0 4rpx rgba(230,126,34,0.14);
}

.preset-avatar:active {
  transform: scale(0.9);
}

/* ── Buttons (暗夜) ───────────────────── */
.btn-cancel {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: rgba(255,255,255,0.05);
  color: #A0A5B0;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 1px solid rgba(255,255,255,0.06);
  box-sizing: border-box;
}

.btn-cancel:active {
  background: rgba(255,255,255,0.08);
}

/* ── Input inside modal override ──────── */
.modal-box .input {
  color: #E8E8ED;
}

/* ── Modal Buttons (legacy, preserved) ─── */
.modal-btns {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
}
